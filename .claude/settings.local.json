{
  "permissions": {
    "allow": [
      "Bash(powershell -Command 'Get-ChildItem -Recurse -File -Depth 3 | Where-Object { $_.FullName -notmatch '\\\\''node_modules|\\\\.git|dist'\\\\'' } | Select-Object FullName')",
